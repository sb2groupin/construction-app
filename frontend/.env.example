# Local dev: Vite proxy forwards /api to the backend target below.
VITE_API_BASE_URL=/api
VITE_BACKEND_PROXY_TARGET=http://localhost:5001
# Production: set this to your deployed backend origin, e.g. https://your-backend.onrender.com
# If VITE_API_BASE_URL is left as /api, the frontend will automatically use VITE_BACKEND_ORIGIN/api.
VITE_BACKEND_ORIGIN=
