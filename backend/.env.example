PORT=5001
# Use either MONGO_URI or MONGODB_URI.
# On Render or other cloud hosts, add this value in the service environment settings.
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/constructionAppDB?retryWrites=true&w=majority
# MONGODB_URI=
JWT_SECRET=apna_strong_access_secret_min_32_chars
JWT_REFRESH_SECRET=apna_strong_refresh_secret_min_32_chars
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
